{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "comment": "preToolUse is required for enforcement; postToolUse output is ignored by Copilot CLI",
        "type": "command",
        "bash": "bash \"$(git rev-parse --show-toplevel)/.hooks/prek-lint.sh\" --adapter copilot",
        "cwd": ".github/hooks",
        "timeoutSec": 120
      }
    ]
  }
}
