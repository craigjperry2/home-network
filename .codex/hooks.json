{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.hooks/nix-lint.sh\" --adapter codex",
            "timeout": 600,
            "statusMessage": "Validating Nix changes"
          }
        ]
      }
    ]
  }
}
