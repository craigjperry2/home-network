{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/nix-lint.sh\"",
            "timeout": 600,
            "statusMessage": "Validating Nix changes"
          }
        ]
      }
    ]
  }
}
